generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Pedido {
  idPedido          Int             @id(map: "PK_Pedidos") @default(autoincrement())
  idCliente         Int?
  fechaSolicitud    DateTime?       @db.Date
  fechaEntrega      DateTime?       @db.Date
  requisitosCliente String?         @db.NVarChar(300)
  comentarios       String?         @db.NVarChar(200)
  cantidadPares     Int?
  total             Int?
  abono             Int?
  estatus           Int?
  recoleccion       String?         @db.NVarChar(9)
  entrega           String?         @db.NVarChar(9)
  pedidosDetalle    PedidoDetalle[]
  cliente           Cliente?        @relation(fields: [idCliente], references: [idCliente], onDelete: NoAction, onUpdate: NoAction, map: "FK_Pedidos_Clientes")

  @@map("Pedidos")
}

model Servicio {
  idServicio     Int             @id(map: "PK_Servicios") @default(autoincrement())
  nombre         String?         @db.NVarChar(30)
  costo          Int?
  tipo           String?         @db.NVarChar(15)
  color          String?         @db.NVarChar(7)
  pedidosDetalle PedidoDetalle[]

  @@map("Servicios")
}

model sysdiagrams {
  name         String @db.NVarChar(128)
  principal_id Int
  diagram_id   Int    @id(map: "PK__sysdiagr__C2B05B61297DB58C") @default(autoincrement())
  version      Int?
  definition   Bytes?

  @@unique([principal_id, name], map: "UK_principal_name")
}

model Cliente {
  idCliente     Int      @id(map: "PK_Clientes") @default(autoincrement())
  nombre        String   @db.NVarChar(120)
  direccion     String   @db.NVarChar(250)
  telefono      String   @db.NVarChar(10)
  fechaRegistro DateTime @db.Date
  pedidos       Pedido[]

  @@map("Clientes")
}

model Usuario {
  idUsuario    Int       @id(map: "PK_Usuarios") @default(autoincrement())
  nombre       String?   @db.NVarChar(20)
  contrasena   String?   @db.NVarChar(Max)
  token        String?   @db.NVarChar(Max)
  ultimoAcceso DateTime? @db.Date

  @@map("Usuarios")
}

model PedidoDetalle {
  idDetalle     Int      @id(map: "PK_ServiciosDetalle") @default(autoincrement())
  idPedido      Int
  idServicio    Int
  cantidadPares Int
  pedido        Pedido   @relation(fields: [idPedido], references: [idPedido], onUpdate: NoAction, map: "FK_PedidoDetalle_Pedidos")
  servicio      Servicio @relation(fields: [idServicio], references: [idServicio], onUpdate: NoAction, map: "FK_PedidoDetalle_Servicios")

  @@map("PedidoDetalles")
}
