{
  "compilerOptions": {
    "incremental": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowJs": false,
    "outDir": "./buildTS/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "CommonJS",
    "target": "es5",
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "jsx": "react",
    "lib": ["es5", "es2015", "dom"],
    "noUnusedLocals": false,
    "allowUnreachableCode": false,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "buildTS", "dist", "build"]
}
