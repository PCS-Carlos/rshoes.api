{
  "compilerOptions": {
    "incremental": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowJs": false,
    "rootDir": "./src",
    "outDir": "./buildTS/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "Node16",
    "target": "es2017",
    "experimentalDecorators": true,
    "moduleResolution": "node16",
    "jsx": "react",
    "lib": ["es2017"],
    "noUnusedLocals": false,
    "allowUnreachableCode": false,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "buildTS", "dist", "build"]
}
